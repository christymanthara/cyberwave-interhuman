{
    "info": {
        "name": "Cyberwave Agent API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Chat - Full Reply",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"message\": \"Can you tell me about emotions in Interhuman?\",\n  \"history\": []\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "http://localhost:8000/v1/chat",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "v1",
                        "chat"
                    ]
                }
            }
        },
        {
            "name": "Chat - Stream (SSE)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Accept",
                        "value": "text/event-stream"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"message\": \"Tell me about the Cyberwave platform\",\n  \"history\": []\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "http://localhost:8000/v1/chat/stream",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "v1",
                        "chat",
                        "stream"
                    ]
                }
            }
        },
        {
            "name": "Healthcheck",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "http://localhost:8000/healthz",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "healthz"
                    ]
                }
            }
        }
    ]
}