{
    "info": {
        "name": "Cyberwave Agent API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000"
        },
        {
            "key": "session_id",
            "value": "session_manual_001"
        }
    ],
    "item": [
        {
            "name": "Upload Analyze (Bootstrap Session)",
            "request": {
                "method": "POST",
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "file",
                            "type": "file",
                            "src": ""
                        },
                        {
                            "key": "session_id",
                            "value": "{{session_id}}",
                            "type": "text"
                        }
                    ]
                },
                "url": {
                    "raw": "{{base_url}}/v1/upload/analyze",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "upload",
                        "analyze"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "const body = pm.response.json();",
                            "if (body && body._session && body._session.session_id) {",
                            "  pm.collectionVariables.set('session_id', body._session.session_id);",
                            "}"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Chat - Full Reply",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"Can you tell me about emotions in Interhuman?\",\n  \"history\": []\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/v1/chat",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "chat"
                    ]
                }
            }
        },
        {
            "name": "Chat - Stream (SSE)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Accept",
                        "value": "text/event-stream"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"Tell me about the Cyberwave platform\",\n  \"history\": []\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/v1/chat/stream",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "chat",
                        "stream"
                    ]
                }
            }
        },
        {
            "name": "Healthcheck",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{base_url}}/healthz",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "healthz"
                    ]
                }
            }
        }
    ]
}